# Copy to .env and fill in. Never commit .env.

# --- OpenAI (required for SEC filing embeddings; optional for chat if using LLM_API_KEY) ---
OPENAI_API_KEY=

# --- Vector store ---
# Filing vectors live in a local SQLite file by default — nothing to set up.
# Setting PINECONE_API_KEY switches every ingest/query to Pinecone serverless.
VECTOR_DB_PATH=./data/vectors.db
PINECONE_API_KEY=
PINECONE_INDEX_NAME=verdict-filings
# Cloud + region for serverless index creation
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# --- SEC EDGAR ---
# REQUIRED: SEC returns 403 without a descriptive User-Agent containing contact info.
# Format: "<App name> <contact email>"
SEC_USER_AGENT=Verdict Research your.email@example.com

# --- NewsAPI (Phase 3) ---
# Free Developer plan key from https://newsapi.org. Leave blank to skip the
# news agent entirely (status="skipped"). Free tier: 100 requests/day, 30-day window.
NEWS_API_KEY=
NEWS_LOOKBACK_DAYS=30
NEWS_MAX_ARTICLES=30

# --- Optional market signal providers ---
# Blank keys are skipped safely. These add analyst ratings, extra quotes,
# fundamentals, institutional-grade history fallbacks, macro context, and retail sentiment.
ALPHAVANTAGE_API_KEY=
FINNHUB_API_KEY=
POLYGON_API_KEY=
TIINGO_API_KEY=
FRED_API_KEY=
STOCKTWITS_ENABLED=true
REDDIT_ENABLED=true
REDDIT_USER_AGENT=VerdictResearch/1.0
SIGNALS_CACHE_SECONDS=300

# --- LLM provider (powers the chatbot + the research report) ---
# The app talks to any OpenAI-compatible endpoint. Easiest FREE option is
# Google Gemini — get a key (no credit card) at https://aistudio.google.com/apikey
# and paste it into LLM_API_KEY.
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_API_KEY=
LLM_MODEL=gemini-2.5-flash
# To use OpenAI instead: leave LLM_BASE_URL blank, set LLM_MODEL=gpt-4o-mini,
# and put a billed key in OPENAI_API_KEY above. To use Groq: set
# LLM_BASE_URL=https://api.groq.com/openai/v1 and LLM_MODEL=llama-3.3-70b-versatile.

# --- Embeddings (SEC RAG; vectors stored locally) ---
# Defaults to OpenAI (needs OPENAI_API_KEY). For a fully FREE setup, point
# embeddings at Gemini's OpenAI-compatible endpoint too — the LLM_API_KEY is
# reused automatically when the base URLs match:
#   EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#   EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# --- CORS (comma-separated) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# --- Operational ---
ENVIRONMENT=development
LOG_LEVEL=INFO
ALLOWED_HOSTS=localhost,127.0.0.1
DOCS_ENABLED=true

# --- Owner authentication ---
# Generate with: openssl rand -base64 48
AUTH_BOOTSTRAP_TOKEN=replace-me-with-a-random-one-time-bootstrap-token
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AUTH_ENCRYPTION_KEY=replace-me-with-a-fernet-key
SESSION_COOKIE_SECURE=false
SESSION_TTL_HOURS=12
SESSION_IDLE_MINUTES=30
LOGIN_CHALLENGE_MINUTES=5
REQUIRE_2FA=true
RATE_LIMIT_AUTH=5/minute

# slowapi syntax: "<count>/<minute|hour>"
RATE_LIMIT_RESEARCH=30/minute
RATE_LIMIT_FILINGS=60/minute
REQUEST_TIMEOUT_SECONDS=120

# Shared run cache + fresh-run quotas. Cache hits avoid fresh LLM calls.
RESEARCH_CACHE_MINUTES=360
DAILY_RUNS_PER_USER=10
DAILY_RUNS_GLOBAL=40

# Server-side alert checks (price alerts + verdict watches). 0 disables the
# background worker; alerts then only trigger while the app is open in a tab.
ALERTS_CHECK_SECONDS=60
# Optional SMTP so triggered alerts also send an email. Leave SMTP_HOST blank
# to skip email — alerts still trigger and show in the UI.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=true

# Default is local SQLite. For HA, swap to Postgres async URI:
#   postgresql+asyncpg://user:pass@host/db
DATABASE_URL=sqlite+aiosqlite:///./data/verdict.db

# Docker ingress. Keep loopback when a TLS reverse proxy runs on the same host.
APP_BIND_ADDRESS=127.0.0.1
APP_PORT=8080

# Production overrides:
# ENVIRONMENT=production
# CORS_ORIGINS=https://verdict.example.com
# ALLOWED_HOSTS=verdict.example.com
# DOCS_ENABLED=false
# SESSION_COOKIE_SECURE=true

# --- Cost tracking (USD per 1M tokens) ---
# Gemini's free tier is $0, so these default to 0 and the UI shows a truthful
# cost. If you switch to paid OpenAI gpt-4o-mini, set 0.15 / 0.60 / 0.02.
COST_INPUT_PER_MTOK_USD=0
COST_OUTPUT_PER_MTOK_USD=0
COST_EMBED_PER_MTOK_USD=0
